# OSF Frontend Environment Variables

# This URL tells the frontend where the backend API lives in production.
# In development, Vite proxys requests dynamically, but in production, we need the direct path.
# Set this to your Render backend domain + /api in Vercel settings (e.g. https://my-backend.onrender.com/api)
# NOTE: Ensure no trailing slash!
VITE_API_URL=https://osf-b.onrender.com/api
